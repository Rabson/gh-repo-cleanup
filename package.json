{
  "name": "@rabson/gh-repo-cleanup",
  "version": "1.0.0",
  "description": "Interactive CLI to safely delete GitHub repositories",
  "type": "module",
  "bin": {
    "gh-delete-repo": "src/index.js"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "start": "node ./src/index.js",
    "dev": "node ./src/index.js",
    "test": "node --test",
    "prepack": "npm test",
    "release:check": "npm test && npm pack --dry-run"
  },
  "keywords": [
    "github",
    "cli",
    "repository",
    "delete",
    "automation"
  ],
  "author": "Rabson",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "preferGlobal": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rabson/gh-delete-repo-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Rabson/gh-delete-repo-cli/issues"
  },
  "homepage": "https://github.com/Rabson/gh-delete-repo-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "commander": "^14.0.0",
    "dotenv": "^16.4.5",
    "inquirer": "^12.4.2",
    "ora": "^8.0.1"
  }
}
